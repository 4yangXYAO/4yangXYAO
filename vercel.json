{
  "version": 2,
  "name": "4yangXYAO-portfolio",
  "builds": [
    {
      "src": "backend/src/server.ts",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/v1/(.*)",
      "destination": "backend/src/server.ts"
    },
    {
      "source": "/(.*)",
      "destination": "frontend/$1"
    }
  ]
}
