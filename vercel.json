{
  "version": 2,
  "builds": [
    {
      "src": "backend/src/server.ts",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    { "src": "/api/v1/(.*)", "dest": "backend/src/server.ts" },
    { "src": "/uploads/(.*)", "dest": "backend/uploads/$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "frontend/$1" },
    { "src": "/(.*)", "dest": "frontend/index.html" }
  ]
}


